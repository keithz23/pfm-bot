generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum TransactionType {
  INCOME   @map("income")
  EXPENSE  @map("expense")
  TRANSFER @map("transfer")
}

enum WalletType {
  CASH     @map("cash")
  BANK     @map("bank")
  E_WALLET @map("e_wallet")
}

model User {
  id            String   @id @default(uuid()) @db.Uuid
  telegramId    BigInt?  @unique @map("telegram_id")
  email         String?  @unique @db.VarChar(255)
  passwordHash  String?  @map("password_hash") @db.Text
  name          String?  @db.VarChar(100)
  currency      String   @default("VND") @db.VarChar(3)
  monthlyBudget Decimal? @map("monthly_budget") @db.Decimal(12, 2)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz

  categories   Category[]
  wallets      Wallet[]
  transactions Transaction[]
  budgets      Budget[]

  @@map("users")
}

model Category {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  name        String   @db.VarChar(100)
  icon        String?  @db.VarChar(50)
  color       String?  @db.VarChar(7)
  budgetLimit Decimal? @map("budget_limit") @db.Decimal(12, 2)
  isDefault   Boolean  @default(false) @map("is_default")
  parentId    String?  @map("parent_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent       Category?     @relation("CategoryTree", fields: [parentId], references: [id])
  children     Category[]    @relation("CategoryTree")
  transactions Transaction[] @relation("TransactionCategory")
  aiSuggested  Transaction[] @relation("AISuggestedCategory")
  budgets      Budget[]

  @@unique([userId, name], name: "userId_name")
  @@index([userId, isDefault])
  @@map("categories")
}

model Wallet {
  id        String     @id @default(uuid()) @db.Uuid
  userId    String     @map("user_id") @db.Uuid
  name      String     @db.VarChar(100)
  type      WalletType
  balance   Decimal    @default(0) @db.Decimal(15, 2)
  color     String?    @db.VarChar(7)
  isDefault Boolean    @default(false) @map("is_default")
  createdAt DateTime   @default(now()) @map("created_at") @db.Timestamptz

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[] @relation("TransactionWallet")
  transfersIn  Transaction[] @relation("TransferToWallet")

  @@map("wallets")
}

model Transaction {
  id                    String          @id @default(uuid()) @db.Uuid
  userId                String          @map("user_id") @db.Uuid
  categoryId            String?         @map("category_id") @db.Uuid
  walletId              String          @map("wallet_id") @db.Uuid
  transferToWalletId    String?         @map("transfer_to_wallet_id") @db.Uuid
  aiSuggestedCategoryId String?         @map("ai_suggested_category_id") @db.Uuid
  type                  TransactionType
  amount                Decimal         @db.Decimal(15, 2)
  description           String?         @db.Text
  transactionDate       DateTime        @map("transaction_date") @db.Date
  note                  String?         @db.Text
  tags                  String[]
  receiptUrl            String?         @map("receipt_url") @db.Text
  createdAt             DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt             DateTime        @updatedAt @map("updated_at") @db.Timestamptz

  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  category            Category? @relation("TransactionCategory", fields: [categoryId], references: [id], onDelete: SetNull)
  wallet              Wallet    @relation("TransactionWallet", fields: [walletId], references: [id])
  transferToWallet    Wallet?   @relation("TransferToWallet", fields: [transferToWalletId], references: [id])
  aiSuggestedCategory Category? @relation("AISuggestedCategory", fields: [aiSuggestedCategoryId], references: [id], onDelete: SetNull)

  @@index([userId, transactionDate(sort: Desc)])
  @@index([userId, categoryId])
  @@index([userId, type, transactionDate(sort: Desc)])
  @@map("transactions")
}

model Budget {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  categoryId  String?  @map("category_id") @db.Uuid
  amount      Decimal  @db.Decimal(12, 2)
  periodMonth DateTime @map("period_month") @db.Date
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([userId, categoryId, periodMonth])
  @@index([userId, periodMonth])
  @@map("budgets")
}
